{
  "name": "create-landing-app",
  "version": "0.3.0",
  "description": "Create a production-ready Next.js landing page with one command",
  "type": "module",
  "bin": {
    "create-landing-app": "./dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "prepublishOnly": "yarn build && rm -rf ./templates && cp -r ../../templates ./templates",
    "test": "node --experimental-vm-modules node_modules/.bin/jest"
  },
  "keywords": [
    "nextjs",
    "landing-page",
    "boilerplate",
    "scaffold",
    "create-app",
    "tailwindcss",
    "typescript",
    "starter"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/LamHana/landing-page-boilerplate"
  },
  "homepage": "https://github.com/LamHana/landing-page-boilerplate#readme",
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "kolorist": "^1.8.0",
    "execa": "^9.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=20.9.0"
  }
}
